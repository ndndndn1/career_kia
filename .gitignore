# 파이썬 빌드 산출물
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 가상환경
.venv/
venv/
env/

# 의존성 락
uv.lock

# 주피터
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# MLflow 실험 로그
mlruns/
mlartifacts/

# 파이프라인 런타임 산출물 — `make all` 로 재생성 가능
# 단, Streamlit Cloud 배포 즉시 동작을 위해 핵심 데모 산출물(<3MB)은 예외 허용
# (디렉터리 자체가 아니라 내용을 ignore 해야 negation 이 동작함 → `*` 사용)
models_artifacts/*
!models_artifacts/hybrid_model.joblib
!models_artifacts/cv_summary.json
xai_artifacts/*
!xai_artifacts/shap_global.parquet
!xai_artifacts/shap_interactions_top10.csv
!xai_artifacts/top_risk_narratives.json
!xai_artifacts/top_risk_narratives.txt
causal_artifacts/*
!causal_artifacts/ate_summary.json
!causal_artifacts/doseresp_*.csv
mlops_artifacts/

# 대용량 원본 데이터 (저장소에 커밋하지 않음)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep
!data/processed/features.parquet

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 테스트/커버리지
.pytest_cache/
.coverage
htmlcov/
.tox/

# Streamlit
.streamlit/secrets.toml
